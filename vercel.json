{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    { "src": "/_stcore/.*", "dest": "api/index.py" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "env": {
    "PYTHON_REQUIREMENTS_FILE": "requirements-vercel.txt"
  }
}
